    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "## 将情感词计数列转换为长格式，便于可视化\n",
        "# value_vars：所有情感计数列（各词典的正面/负面词计数）\n",
        "# var_name：存储原始列名（包含情感类别和来源信息）\n",
        "# value_name：存储对应计数\n",
        "df_melted = df.melt(\n",
        "    value_vars = [\n",
        "        'positive_words_iSOL','negative_words_iSOL',\n",
        "        'positive_words_NRC','negative_words_NRC',\n",
        "        'positive_words_mlSenticon','negative_words_mlSenticon',\n",
        "    ],\n",
        "    var_name = 'sentiment_and_source',\n",
        "    value_name = 'count',\n",
        ")\n",
        "\n",
        "df_melted.head()  # 初始长格式结果，尚未进一步处理"
      ],
